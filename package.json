{
  "name": "feishu-coding-bot",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.11.0 <21",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "bash scripts/dev-all.sh",
    "build": "pnpm -r build",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "pnpm -r --if-present run typecheck",
    "smoke": "bash scripts/smoke.sh",
    "fake-agent": "node scripts/fake-agent-core.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0",
    "ws": "^8.16.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
