# ── Feishu (bot-host only) ──────────────────────────────────────
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_BOT_OPEN_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Whitelist (bot-host only) — comma-separated ─────────────────
ALLOWED_CHAT_IDS=oc_test_chat_id
ALLOWED_USER_IDS=ou_test_user_id

# ── Inner WS Server (bot-host listens, AI_Proxy connects in) ───
INNER_WS_HOST=0.0.0.0
INNER_WS_PORT=8765
AI_PROXY_MODEL=                  # optional, leave empty for default

# ── User -> Device routing ─────────────────────────────────────
# Format: user_open_id:device_id, comma-separated
# Leave empty = single device mode (any connected AI_Proxy handles all)
# Each AI_Proxy must start with matching --device-id
USER_DEVICE_MAP=

# ── Storage (bot-host only) ─────────────────────────────────────
AUDIT_DB_PATH=./data/audit.db

# ── Runtime ─────────────────────────────────────────────────────
LOG_LEVEL=info                    # trace|debug|info|warn|error
REPLY_THROTTLE_MS=2000